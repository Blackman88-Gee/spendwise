<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spendwise.controller.BudgetsController"
      spacing="14" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Budgets" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Set Budget" onAction="#onAddBudget" styleClass="primary-button"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-area">
        <VBox fx:id="budgetCardsContainer" spacing="12"/>
    </ScrollPane>
</VBox>
