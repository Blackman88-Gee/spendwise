<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spendwise.controller.DashboardController"
      spacing="16" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Dashboard" styleClass="screen-title"/>

    <HBox spacing="16">
        <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Total Balance" styleClass="card-label"/>
            <Label fx:id="balanceLabel" styleClass="card-value"/>
        </VBox>
        <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="This Month — Income" styleClass="card-label"/>
            <Label fx:id="monthIncomeLabel" styleClass="card-value-income"/>
        </VBox>
        <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="This Month — Expenses" styleClass="card-label"/>
            <Label fx:id="monthExpenseLabel" styleClass="card-value-expense"/>
        </VBox>
    </HBox>

    <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
        <Label text="Recent Transactions" styleClass="card-section-title"/>
        <ListView fx:id="recentList" VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>
