<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spendwise.controller.RecurringController"
      spacing="14" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Recurring Transactions" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Recurring Rule" onAction="#onAddRule" styleClass="primary-button"/>
    </HBox>

    <Label text="Bills and subscriptions due on or before today are turned into real transactions automatically each time SpendWise starts."
           styleClass="placeholder-text" wrapText="true"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="80"/>
            <TableColumn fx:id="categoryColumn" text="Category" prefWidth="130"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="90"/>
            <TableColumn fx:id="frequencyColumn" text="Frequency" prefWidth="100"/>
            <TableColumn fx:id="nextDueColumn" text="Next Due" prefWidth="100"/>
            <TableColumn fx:id="activeColumn" text="Active" prefWidth="70"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
