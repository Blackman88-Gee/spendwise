<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spendwise.controller.TransactionsController"
      spacing="14" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Transactions" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Transaction" onAction="#onAddTransaction" styleClass="primary-button"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
        <Label text="Category:"/>
        <ComboBox fx:id="filterCategoryCombo" prefWidth="160"/>
        <Label text="From:"/>
        <DatePicker fx:id="filterStartDate" prefWidth="140"/>
        <Label text="To:"/>
        <DatePicker fx:id="filterEndDate" prefWidth="140"/>
        <TextField fx:id="searchField" promptText="Search description..." prefWidth="180"/>
        <Button text="Reset" onAction="#onResetFilters"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="80"/>
            <TableColumn fx:id="categoryColumn" text="Category" prefWidth="140"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="260"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="110"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="140"/>
        </columns>
    </TableView>

    <Label fx:id="summaryLabel" styleClass="placeholder-text"/>
</VBox>
